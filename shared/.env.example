# Shared LLM/provider settings used by agents that call build_agent_model().
# Copy to shared/.env and fill in real values. Do not commit shared/.env.

GOOGLE_API_KEY=your_google_api_key_here

# multi_agents defaults to Azure
MULTI_AGENTS_PROVIDER=azure
MULTI_AGENTS_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
MULTI_AGENTS_AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
MULTI_AGENTS_AZURE_OPENAI_API_VERSION=v1
MULTI_AGENTS_AZURE_OPENAI_MODEL=your_azure_deployment_name
MULTI_AGENTS_MAX_OUTPUT_TOKENS=256
# MULTI_AGENTS_GOOGLE_MODEL=gemini-2.0-flash

# ati_search defaults to Azure
ATI_SEARCH_PROVIDER=azure
ATI_SEARCH_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
ATI_SEARCH_AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
ATI_SEARCH_AZURE_OPENAI_API_VERSION=v1
ATI_SEARCH_AZURE_OPENAI_MODEL=your_azure_deployment_name
ATI_SEARCH_MAX_OUTPUT_TOKENS=256
# ATI_SEARCH_GOOGLE_MODEL=gemini-2.0-flash
